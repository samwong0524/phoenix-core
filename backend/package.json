{
  "name": "phoenix-core-backend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p 3100 --webpack",
    "build": "next build --webpack",
    "start": "next start -H 127.0.0.1 -p 3100",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lh": "lighthouse http://localhost:3100/im --output=json --output-path=./lighthouse-reports/im.json --chrome-flags=\"--no-sandbox\"",
    "lh:ci": "npx lhci autorun",
    "prepare": "husky",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "a11y": "playwright test e2e/accessibility.spec.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npx tsc --noEmit"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.23.0",
    "@streamdown/code": "^1.0.1",
    "@streamdown/mermaid": "^1.0.1",
    "@xyflow/react": "^12.11.1",
    "bcryptjs": "^3.0.3",
    "dagre": "^0.8.5",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^11.2.10",
    "immer": "^11.1.8",
    "jose": "^6.2.3",
    "lucide-react": "^0.469.0",
    "next": "^16.1.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtuoso": "^4.18.10",
    "redis": "^4.7.0",
    "streamdown": "^2.1.0",
    "zod": "^4.3.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bcryptjs": "^2.4.6",
    "@types/dagre": "^0.7.54",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.23",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lighthouse": "^13.4.0",
    "lint-staged": "^17.0.8",
    "madge": "^8.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
