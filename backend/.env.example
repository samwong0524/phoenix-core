# Backend
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent_wechat
REDIS_URL=redis://localhost:6379
LLM_PROVIDER=glm
GLM_API_KEY=replace_me
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
