# Backend
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent_wechat
REDIS_URL=redis://localhost:6379
LLM_PROVIDER=glm
GLM_API_KEY=replace_me
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_MODEL=glm-4.7

# OpenRouter (OpenAI-compatible)
OPENROUTER_API_KEY=replace_me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=

# Ollama (local OpenAI-compatible, no API key needed)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1/chat/completions
# OLLAMA_MODEL=qwen3:8b

# Anthropic (Claude API)
# LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=replace_me
# ANTHROPIC_BASE_URL=
# ANTHROPIC_MODEL=qwen3.6-plus

# Alternate database URL formats (Vercel / Prisma compat)
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=
# POSTGRES_PRISMA_URL=

# MCP server configuration
# MCP_CONFIG_PATH=
# MCP_TIMEOUT_MS=30000
# MCP_LOAD_TIMEOUT_MS=2000

# MCP Tool API Keys (used by servers in mcp.json)
# TAVILY_API_KEY=tvly-prod-YOUR_KEY_HERE

# Agent runtime directories
# AGENT_WORKDIR=
# AGENT_SKILLS_DIR=
# AGENT_LOG_DIR=
# AGENT_STREAM_LOG_DIR=
# AGENT_LLM_REQUEST_LOG_DIR=
